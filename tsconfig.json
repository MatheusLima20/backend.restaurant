{
    "compilerOptions": {
        "lib": [
           "es5",
           "es6"
        ],
        "target": "es6",
        "module": "commonjs",
        "moduleResolution": "bundler",
        "rootDir": "./src",
        "outDir": "./build",
        "typeRoots" : ["src/@types", "./node_modules/@types"],
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "sourceMap": true
    }
}